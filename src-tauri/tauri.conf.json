{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Personal Assistant",
  "version": "0.1.0",
  "identifier": "com.personalassistant.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Personal Assistant",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:8787 ws://127.0.0.1:8787"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
